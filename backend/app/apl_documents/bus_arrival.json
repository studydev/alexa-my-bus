{
  "type": "APL",
  "version": "2024.3",
  "license": "BusWatch Home APL Template — Responsive",
  "theme": "dark",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "resources": [
    {
      "colors": {
        "busBlue": "#1976D2",
        "busRed": "#D32F2F",
        "busGreen": "#388E3C",
        "textPrimary": "#FFFFFF",
        "textSecondary": "#B6C6D3",
        "textDim": "#6F8393",
        "bgDark": "#05080C",
        "panelBus": "#0E141B",
        "panelWeather": "#0C141C",
        "weatherHero": "#1B5265",
        "weatherHeroSoft": "#163D4B",
        "weatherCard": "#111B24",
        "weatherChip": "#16232D",
        "weatherLine": "#253746",
        "forecastCell": "#16212B",
        "forecastWet": "#1B2A38",
        "accentGreen": "#59D47A",
        "accentOrange": "#FFB347",
        "accentRed": "#FF6B6B",
        "tempMax": "#FF8A4D",
        "tempMin": "#6EBBFF",
        "footerText": "#485968"
      },
      "dimensions": {
        "panelPad": "2vw",
        "panelRadius": "3.5vh",
        "cardRadius": "3vh",
        "chipRadius": "2.5vh",
        "gapSm": "1.2vh",
        "gapMd": "1.8vh",
        "gapLg": "2vh",
        "fontHuge": "14vh",
        "fontXL": "12vh",
        "fontLg": "9vh",
        "fontRoute": "5.5vh",
        "fontStat": "4.2vh",
        "fontCity": "3.8vh",
        "fontDesc": "2.8vh",
        "fontLabel": "2vh",
        "fontBody": "2.2vh",
        "fontCaption": "1.8vh",
        "fontMicro": "1.5vh",
        "badgeW": "55%",
        "badgeH": "11vh",
        "weatherHeroHeight": "31vh",
        "weatherStatsHeight": "12.5vh",
        "weatherCity": "3.2vh",
        "weatherEmoji": "9.5vh",
        "weatherTemp": "8vh",
        "weatherDegree": "3.8vh",
        "weatherDesc": "2vh",
        "weatherStatValue": "3.2vh",
        "weatherSummaryTemp": "3.4vh",
        "weatherSummaryMeta": "1.8vh",
        "weatherForecastTemp": "1.9vh",
        "weatherForecastEmoji": "2.6vh",
        "weatherSectionGap": "1.2vh",
        "fontCaptionDouble": "3.6vh",
        "fontMicroDouble": "3vh",
        "weatherSummaryLabelTriple": "5.4vh",
        "weatherSummaryTempTriple": "10.2vh",
        "weatherSummaryMetaDouble": "3.6vh",
        "weatherHeroSpacer": "9.5vh",
        "weatherStatLabel": "3vh",
        "weatherDescDouble": "4vh"
      }
    }
  ],
  "layouts": {
    "BusPanel": {
      "parameters": ["busData"],
      "items": [
        {
          "type": "Frame",
          "width": "100%",
          "height": "100%",
          "backgroundColor": "@panelBus",
          "borderRadius": "@panelRadius",
          "paddingLeft": "@panelPad",
          "paddingRight": "@panelPad",
          "paddingTop": "@panelPad",
          "paddingBottom": "@panelPad",
          "items": [
            {
              "type": "Container",
              "width": "100%",
              "height": "100%",
              "direction": "column",
              "alignItems": "center",
              "items": [
                {
                  "type": "Text",
                  "text": "실시간 버스",
                  "fontSize": "@fontCaptionDouble",
                  "color": "@textDim",
                  "textAlign": "center",
                  "width": "100%"
                },
                {
                  "type": "Container",
                  "width": "100%",
                  "alignItems": "center",
                  "paddingTop": "@gapMd",
                  "items": [
                    {
                      "type": "Frame",
                      "width": "@badgeW",
                      "height": "@badgeH",
                      "backgroundColor": "${busData.routeType == 'red' ? '@busRed' : (busData.routeType == 'green' ? '@busGreen' : '@busBlue')}",
                      "borderRadius": "@chipRadius",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "height": "100%",
                          "alignItems": "center",
                          "justifyContent": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "${busData.routeName}",
                              "fontSize": "@fontRoute",
                              "fontWeight": "900",
                              "color": "@textPrimary",
                              "textAlign": "center"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Text",
                      "text": "${busData.stationName}",
                      "fontSize": "@fontBody",
                      "color": "@textSecondary",
                      "paddingTop": "@gapSm",
                      "textAlign": "center",
                      "maxLines": 2
                    }
                  ]
                },
                {
                  "when": "${busData.flag == 'RUN' || busData.flag == 'WAIT' || (busData.flag == 'PASS' && busData.predictTime1 != null)}",
                  "type": "Container",
                  "grow": 1,
                  "width": "100%",
                  "justifyContent": "center",
                  "items": [
                    {
                      "type": "Frame",
                      "width": "100%",
                      "backgroundColor": "${busData.predictTime1 != null && busData.predictTime1 <= 3 ? '#321317' : (busData.predictTime1 != null && busData.predictTime1 <= 7 ? '#372413' : '#112218')}",
                      "borderRadius": "@cardRadius",
                      "paddingLeft": "@panelPad",
                      "paddingRight": "@panelPad",
                      "paddingTop": "@gapLg",
                      "paddingBottom": "@gapLg",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "alignItems": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "다음 버스",
                              "fontSize": "@fontBody",
                              "color": "@textSecondary"
                            },
                            {
                              "type": "Container",
                              "direction": "row",
                              "alignItems": "end",
                              "justifyContent": "center",
                              "paddingTop": "0.8vh",
                              "items": [
                                {
                                  "type": "Text",
                                  "text": "${busData.predictTime1 != null ? busData.predictTime1 : '--'}",
                                  "fontSize": "@fontHuge",
                                  "fontWeight": "900",
                                  "color": "${busData.predictTime1 != null && busData.predictTime1 <= 3 ? '@accentRed' : (busData.predictTime1 != null && busData.predictTime1 <= 7 ? '@accentOrange' : '@accentGreen')}"
                                },
                                {
                                  "type": "Text",
                                  "text": "분",
                                  "fontSize": "@fontDesc",
                                  "color": "@textSecondary",
                                  "paddingLeft": "0.5vw",
                                  "paddingBottom": "2.5vh"
                                }
                              ]
                            },
                            {
                              "when": "${busData.locationNo1 != null}",
                              "type": "Text",
                              "text": "${busData.locationNo1}개 전 · ${busData.stationNm1}",
                              "fontSize": "@fontLabel",
                              "color": "@textDim",
                              "textAlign": "center",
                              "paddingTop": "0.5vh"
                            },
                            {
                              "when": "${busData.lowPlate1 == '1'}",
                              "type": "Text",
                              "text": "저상버스 운행",
                              "fontSize": "@fontCaption",
                              "color": "@textSecondary",
                              "paddingTop": "1vh"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "when": "${busData.predictTime2 != null}",
                      "type": "Frame",
                      "width": "100%",
                      "height": "@gapMd",
                      "backgroundColor": "transparent"
                    },
                    {
                      "when": "${busData.predictTime2 != null}",
                      "type": "Frame",
                      "width": "100%",
                      "backgroundColor": "#121B24",
                      "borderRadius": "@cardRadius",
                      "paddingLeft": "@panelPad",
                      "paddingRight": "@panelPad",
                      "paddingTop": "@gapMd",
                      "paddingBottom": "@gapMd",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "alignItems": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "다다음 버스",
                              "fontSize": "@fontLabel",
                              "color": "@textSecondary"
                            },
                            {
                              "type": "Container",
                              "direction": "row",
                              "alignItems": "end",
                              "justifyContent": "center",
                              "paddingTop": "0.5vh",
                              "items": [
                                {
                                  "type": "Text",
                                  "text": "${busData.predictTime2}",
                                  "fontSize": "@fontLg",
                                  "fontWeight": "900",
                                  "color": "@textPrimary"
                                },
                                {
                                  "type": "Text",
                                  "text": "분",
                                  "fontSize": "@fontBody",
                                  "color": "@textSecondary",
                                  "paddingLeft": "0.5vw",
                                  "paddingBottom": "1.8vh"
                                }
                              ]
                            },
                            {
                              "when": "${busData.locationNo2 != null}",
                              "type": "Text",
                              "text": "${busData.locationNo2}개 전 · ${busData.stationNm2}",
                              "fontSize": "@fontCaption",
                              "color": "@textDim",
                              "textAlign": "center"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "when": "${(busData.flag == 'PASS' && busData.predictTime1 == null) || busData.flag == 'STOP'}",
                  "type": "Container",
                  "grow": 1,
                  "width": "100%",
                  "justifyContent": "center",
                  "items": [
                    {
                      "type": "Frame",
                      "width": "100%",
                      "backgroundColor": "#121B24",
                      "borderRadius": "@cardRadius",
                      "paddingLeft": "@panelPad",
                      "paddingRight": "@panelPad",
                      "paddingTop": "4vh",
                      "paddingBottom": "4vh",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "alignItems": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "${busData.flag == 'PASS' ? '🌙' : '⏳'}",
                              "fontSize": "@fontLg"
                            },
                            {
                              "type": "Text",
                              "text": "${busData.flag == 'PASS' ? '운행이 종료되었습니다' : '운행 준비 중입니다'}",
                              "fontSize": "@fontDesc",
                              "color": "@textSecondary",
                              "textAlign": "center",
                              "paddingTop": "@gapSm"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "when": "${busData.flag == 'ERROR'}",
                  "type": "Container",
                  "grow": 1,
                  "width": "100%",
                  "justifyContent": "center",
                  "items": [
                    {
                      "type": "Frame",
                      "width": "100%",
                      "backgroundColor": "#241214",
                      "borderRadius": "@cardRadius",
                      "paddingLeft": "@panelPad",
                      "paddingRight": "@panelPad",
                      "paddingTop": "4vh",
                      "paddingBottom": "4vh",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "alignItems": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "⚠️",
                              "fontSize": "@fontLg"
                            },
                            {
                              "type": "Text",
                              "text": "버스 정보를 불러올 수 없습니다",
                              "fontSize": "@fontDesc",
                              "color": "@accentRed",
                              "textAlign": "center",
                              "paddingTop": "@gapSm"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Text",
                  "text": "업데이트 ${busData.lastUpdated}",
                  "fontSize": "@fontMicroDouble",
                  "color": "@footerText",
                  "textAlign": "center",
                  "width": "100%",
                  "paddingTop": "@gapMd"
                }
              ]
            }
          ]
        }
      ]
    },
    "StatCard": {
      "parameters": ["label", "value", "sub"],
      "items": [
        {
          "type": "Frame",
          "grow": 1,
          "backgroundColor": "@weatherChip",
          "borderRadius": "@chipRadius",
          "paddingLeft": "1.2vw",
          "paddingRight": "1.2vw",
          "paddingTop": "1.2vh",
          "paddingBottom": "1.2vh",
          "items": [
            {
              "type": "Container",
              "height": "100%",
              "direction": "column",
              "justifyContent": "spaceBetween",
              "alignItems": "center",
              "items": [
                {
                  "type": "Text",
                  "text": "${label}",
                  "fontSize": "@weatherStatLabel",
                  "color": "@textDim",
                  "textAlign": "center",
                  "width": "100%"
                },
                {
                  "type": "Text",
                  "text": "${value}",
                  "fontSize": "@weatherStatValue",
                  "fontWeight": "900",
                  "color": "@textPrimary",
                  "textAlign": "center",
                  "width": "100%"
                },
                {
                  "when": "${sub}",
                  "type": "Text",
                  "text": "${sub}",
                  "fontSize": "@fontMicro",
                  "color": "@textSecondary",
                  "textAlign": "center",
                  "width": "100%"
                }
              ]
            }
          ]
        }
      ]
    },
    "WeatherPanel": {
      "parameters": ["weatherData"],
      "items": [
        {
          "when": "${!weatherData}",
          "type": "Frame",
          "width": "100%",
          "height": "100%",
          "backgroundColor": "@panelWeather",
          "borderRadius": "@panelRadius",
          "items": [
            {
              "type": "Container",
              "width": "100%",
              "height": "100%",
              "alignItems": "center",
              "justifyContent": "center",
              "items": [
                {
                  "type": "Text",
                  "text": "🌡️",
                  "fontSize": "@fontLg"
                },
                {
                  "type": "Text",
                  "text": "날씨 정보를 불러올 수 없습니다",
                  "fontSize": "@fontDesc",
                  "color": "@textSecondary",
                  "paddingTop": "@gapSm"
                }
              ]
            }
          ]
        },
        {
          "when": "${weatherData}",
          "type": "Frame",
          "width": "100%",
          "height": "100%",
          "backgroundColor": "@panelWeather",
          "borderRadius": "@panelRadius",
          "paddingLeft": "@panelPad",
          "paddingRight": "@panelPad",
          "paddingTop": "@panelPad",
          "paddingBottom": "@panelPad",
          "items": [
            {
              "type": "Container",
              "width": "100%",
              "height": "100%",
              "direction": "column",
              "alignItems": "center",
              "items": [
                {
                  "type": "Container",
                  "width": "100%",
                  "alignItems": "center",
                  "items": [
                    {
                      "type": "Text",
                      "text": "현재 날씨",
                      "fontSize": "@fontCaptionDouble",
                      "color": "@textDim",
                      "textAlign": "center",
                      "width": "100%"
                    },
                    {
                      "type": "Text",
                      "text": "${weatherData.city ? weatherData.city : '현재 위치'}",
                      "fontSize": "@weatherCity",
                      "fontWeight": "900",
                      "color": "@textPrimary",
                      "paddingTop": "0.5vh",
                      "textAlign": "center"
                    }
                  ]
                },
                {
                  "type": "Frame",
                  "width": "100%",
                  "height": "@weatherSectionGap",
                  "backgroundColor": "transparent"
                },
                {
                  "type": "Frame",
                  "width": "100%",
                  "height": "@weatherHeroHeight",
                  "backgroundColor": "@weatherHero",
                  "borderRadius": "@cardRadius",
                  "paddingLeft": "1.6vw",
                  "paddingRight": "1.6vw",
                  "paddingTop": "1.4vh",
                  "paddingBottom": "1.4vh",
                  "items": [
                    {
                      "type": "Container",
                      "width": "100%",
                      "height": "100%",
                      "direction": "row",
                      "justifyContent": "center",
                      "alignItems": "center",
                      "items": [
                        {
                          "type": "Container",
                          "grow": 7,
                          "direction": "row",
                          "alignItems": "center",
                          "justifyContent": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "${weatherData.emoji}",
                              "fontSize": "@weatherEmoji",
                              "paddingRight": "1vw"
                            },
                            {
                              "type": "Frame",
                              "width": "@weatherHeroSpacer",
                              "height": "1dp",
                              "backgroundColor": "transparent"
                            },
                            {
                              "type": "Container",
                              "alignItems": "center",
                              "items": [
                                {
                                  "type": "Text",
                                  "text": "오늘 날씨",
                                  "fontSize": "@fontCaptionDouble",
                                  "color": "#D3E4EC",
                                  "textAlign": "center",
                                  "width": "100%"
                                },
                                {
                                  "type": "Container",
                                  "direction": "row",
                                  "alignItems": "end",
                                  "justifyContent": "center",
                                  "width": "100%",
                                  "items": [
                                    {
                                      "type": "Text",
                                      "text": "${weatherData.temp}",
                                      "fontSize": "@weatherTemp",
                                      "fontWeight": "900",
                                      "color": "@textPrimary"
                                    },
                                    {
                                      "type": "Text",
                                      "text": "°",
                                      "fontSize": "@weatherDegree",
                                      "color": "#D3E4EC",
                                      "paddingBottom": "1.4vh"
                                    }
                                  ]
                                },
                                {
                                  "type": "Text",
                                  "text": "${weatherData.description}",
                                  "fontSize": "@weatherDescDouble",
                                  "fontWeight": "700",
                                  "color": "#E8F1F5",
                                  "textAlign": "center",
                                  "width": "100%"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "Frame",
                          "width": "1.2vw",
                          "height": "1dp",
                          "backgroundColor": "transparent"
                        },
                        {
                          "type": "Frame",
                          "grow": 5,
                          "height": "100%",
                          "backgroundColor": "@weatherHeroSoft",
                          "borderRadius": "@cardRadius",
                          "paddingLeft": "1.1vw",
                          "paddingRight": "1.1vw",
                          "paddingTop": "1vh",
                          "paddingBottom": "1vh",
                          "items": [
                            {
                              "type": "Container",
                              "width": "100%",
                              "height": "100%",
                              "direction": "column",
                              "justifyContent": "spaceBetween",
                              "items": [
                                {
                                  "type": "Text",
                                  "text": "오늘 요약",
                                  "fontSize": "@fontCaptionDouble",
                                  "color": "#D3E4EC"
                                },
                                {
                                  "type": "Container",
                                  "width": "100%",
                                  "direction": "row",
                                  "justifyContent": "spaceAround",
                                  "items": [
                                    {
                                      "type": "Container",
                                      "alignItems": "center",
                                      "items": [
                                        {
                                          "type": "Text",
                                          "text": "최고",
                                          "fontSize": "@fontCaptionDouble",
                                          "color": "#BFD4DE"
                                        },
                                        {
                                          "type": "Text",
                                          "text": "${weatherData.tempMax}°",
                                          "fontSize": "@weatherSummaryLabelTriple",
                                          "fontWeight": "900",
                                          "color": "@tempMax"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "Container",
                                      "alignItems": "center",
                                      "items": [
                                        {
                                          "type": "Text",
                                          "text": "최저",
                                          "fontSize": "@fontCaptionDouble",
                                          "color": "#BFD4DE"
                                        },
                                        {
                                          "type": "Text",
                                          "text": "${weatherData.tempMin}°",
                                          "fontSize": "@weatherSummaryLabelTriple",
                                          "fontWeight": "900",
                                          "color": "@tempMin"
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "Frame",
                                  "width": "100%",
                                  "height": "1dp",
                                  "backgroundColor": "#2F5867"
                                },
                                {
                                  "type": "Text",
                                  "text": "체감 ${weatherData.feelsLike}° · 강수 최대 ${weatherData.popMax}%",
                                  "fontSize": "@weatherSummaryMetaDouble",
                                  "color": "#E8F1F5",
                                  "textAlign": "center",
                                  "width": "100%"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "Frame",
                  "width": "100%",
                  "height": "@weatherSectionGap",
                  "backgroundColor": "transparent"
                },
                {
                  "type": "Container",
                  "width": "100%",
                  "height": "@weatherStatsHeight",
                  "direction": "row",
                  "alignItems": "stretch",
                  "items": [
                    {
                      "type": "StatCard",
                      "label": "습도",
                      "value": "${weatherData.humidity}%"
                    },
                    {
                      "type": "Frame",
                      "width": "0.6vw",
                      "backgroundColor": "transparent"
                    },
                    {
                      "type": "StatCard",
                      "label": "바람",
                      "value": "${weatherData.windSpeed}m/s"
                    },
                    {
                      "type": "Frame",
                      "width": "0.6vw",
                      "backgroundColor": "transparent"
                    },
                    {
                      "type": "StatCard",
                      "label": "구름량",
                      "value": "${weatherData.clouds}%"
                    },
                    {
                      "type": "Frame",
                      "width": "0.6vw",
                      "backgroundColor": "transparent"
                    },
                    {
                      "type": "StatCard",
                      "label": "일출 / 일몰",
                      "value": "${weatherData.sunrise}",
                      "sub": "일몰 ${weatherData.sunset}"
                    }
                  ]
                },
                {
                  "type": "Frame",
                  "width": "100%",
                  "height": "@weatherSectionGap",
                  "backgroundColor": "transparent"
                },
                {
                  "type": "Frame",
                  "width": "100%",
                  "grow": 1,
                  "backgroundColor": "@weatherCard",
                  "borderRadius": "@cardRadius",
                  "paddingLeft": "1.2vw",
                  "paddingRight": "1.2vw",
                  "paddingTop": "1.2vh",
                  "paddingBottom": "1.2vh",
                  "items": [
                    {
                      "type": "Container",
                      "width": "100%",
                      "height": "100%",
                      "direction": "column",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "direction": "row",
                          "justifyContent": "spaceBetween",
                          "alignItems": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "24시간 예보",
                              "fontSize": "@fontBody",
                              "fontWeight": "700",
                              "color": "@textPrimary"
                            },
                            {
                              "type": "Text",
                              "text": "3시간 단위",
                              "fontSize": "@fontMicro",
                              "color": "@textDim"
                            }
                          ]
                        },
                        {
                          "type": "Frame",
                          "width": "100%",
                          "height": "@gapSm",
                          "backgroundColor": "transparent"
                        },
                        {
                          "type": "Frame",
                          "width": "100%",
                          "height": "1dp",
                          "backgroundColor": "@weatherLine"
                        },
                        {
                          "type": "Frame",
                          "width": "100%",
                          "height": "@gapSm",
                          "backgroundColor": "transparent"
                        },
                        {
                          "type": "Container",
                          "width": "100%",
                          "grow": 1,
                          "direction": "row",
                          "alignItems": "stretch",
                          "data": "${weatherData.forecast}",
                          "items": [
                            {
                              "type": "Container",
                              "grow": 1,
                              "paddingRight": "0.5vw",
                              "items": [
                                {
                                  "type": "Frame",
                                  "width": "100%",
                                  "height": "100%",
                                  "backgroundColor": "${data.pop > 0 ? '@forecastWet' : '@forecastCell'}",
                                  "borderRadius": "@chipRadius",
                                  "paddingLeft": "0.4vw",
                                  "paddingRight": "0.4vw",
                                  "paddingTop": "0.8vh",
                                  "paddingBottom": "0.8vh",
                                  "items": [
                                    {
                                      "type": "Container",
                                      "width": "100%",
                                      "height": "100%",
                                      "direction": "column",
                                      "alignItems": "center",
                                      "items": [
                                        {
                                          "type": "Text",
                                          "text": "${data.time}",
                                          "fontSize": "@fontMicro",
                                          "color": "@textDim",
                                          "textAlign": "center"
                                        },
                                        {
                                          "type": "Frame",
                                          "width": "1dp",
                                          "height": "${data.topPadding}dp",
                                          "backgroundColor": "transparent"
                                        },
                                        {
                                          "type": "Frame",
                                          "width": "1.8vh",
                                          "height": "1.8vh",
                                          "backgroundColor": "${data.tempColor}",
                                          "borderRadius": "0.9vh"
                                        },
                                        {
                                          "type": "Text",
                                          "text": "${data.temp}°",
                                          "fontSize": "@weatherForecastTemp",
                                          "fontWeight": "800",
                                          "color": "${data.tempColor}",
                                          "textAlign": "center",
                                          "paddingTop": "0.8vh"
                                        },
                                        {
                                          "type": "Text",
                                          "text": "${data.emoji}",
                                          "fontSize": "@weatherForecastEmoji",
                                          "textAlign": "center",
                                          "paddingTop": "0.4vh"
                                        },
                                        {
                                          "type": "Frame",
                                          "grow": 1,
                                          "width": "1dp",
                                          "backgroundColor": "transparent"
                                        },
                                        {
                                          "type": "Text",
                                          "text": "강수 ${data.pop}%",
                                          "fontSize": "@fontMicro",
                                          "color": "${data.pop > 0 ? '#6EBBFF' : '#6F8393'}",
                                          "textAlign": "center"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "mainTemplate": {
    "parameters": ["busData", "weatherData"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "backgroundColor": "@bgDark",
        "paddingLeft": "1.5vw",
        "paddingRight": "1.5vw",
        "paddingTop": "2vh",
        "paddingBottom": "1.2vh",
        "direction": "column",
        "items": [
          {
            "type": "Container",
            "width": "100%",
            "grow": 1,
            "direction": "row",
            "alignItems": "stretch",
            "items": [
              {
                "type": "Container",
                "grow": 1,
                "paddingRight": "0.7vw",
                "items": [
                  {
                    "type": "BusPanel",
                    "busData": "${busData}",
                    "width": "100%",
                    "height": "100%"
                  }
                ]
              },
              {
                "type": "Container",
                "grow": 2,
                "paddingLeft": "0.7vw",
                "items": [
                  {
                    "type": "WeatherPanel",
                    "weatherData": "${weatherData}",
                    "width": "100%",
                    "height": "100%"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "onMount": [
    {
      "type": "SendEvent",
      "delay": 60000,
      "arguments": ["refresh"]
    }
  ],
  "handleTick": [
    {
      "minimumDelay": 60000,
      "commands": [
        {
          "type": "SendEvent",
          "arguments": ["refresh"]
        }
      ]
    }
  ]
}
