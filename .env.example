# ============================================
# BusWatch Home 환경 변수 설정
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env
# ============================================

# --- GBIS 공공데이터 API ---
# 경기도 버스 도착 정보 API (기본값 — 변경 불필요)
GBUS_API_URL=https://apis.data.go.kr/6410000/busarrivalservice/v2
GBUS_ROUTE_API_URL=https://apis.data.go.kr/6410000/busrouteservice/v2
GBUS_STATION_API_URL=https://apis.data.go.kr/6410000/busstationservice/v2

# 공공데이터포털(data.go.kr)에서 발급받은 인증키 (URL 인코딩된 값)
PUBLIC_DATA_API_KEY=여기에_공공데이터포털_API_키_입력

# --- 기본 정류소/노선 설정 ---
# settings.json이 없거나 비어 있을 때 사용되는 기본값
# 웹 UI(/settings)에서 변경하면 settings.json이 우선 적용됩니다.
STATION_ID=224000050
STATION_NAME=목감중심상업지구
ROUTE_ID=216000047
ROUTE_NAME=5602

# openwheathermap API 키
OPENWEATHERMAP_API_KEY=여기에_OpenWeatherMap_API_키_입력

# --- Amazon Developer 계정 키 ---
# Amazon Developer 계정에서 발급받은 키를 입력하세요.
AMAZON_SHARED_KEY=여기에_Amazon_Shared_Key_입력
AMAZON_CLIENT_ID=여기에_Amazon_Client_ID_입력
AMAZON_SECRET_KEY=여기에_Amazon_Secret_Key_입력

# Azure Speech TTS
AZURE_SPEECH_KEY=여기에_Azure_Speech_Key_입력
AZURE_SPEECH_REGION=여기에_Azure_Speech_Region_입력
