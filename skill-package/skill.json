{
  "manifest": {
    "apis": {
      "custom": {
        "endpoint": {
          "uri": "https://bus.studydev.com/alexa",
          "sslCertificateType": "Trusted"
        },
        "interfaces": [
          {
            "type": "ALEXA_PRESENTATION_APL",
            "supportedViewports": [
              {
                "mode": "HUB",
                "shape": "RECTANGLE",
                "minWidth": 1024,
                "maxWidth": 1920,
                "minHeight": 600,
                "maxHeight": 1200
              }
            ]
          }
        ]
      }
    },
    "manifestVersion": "1.0",
    "publishingInformation": {
      "locales": {
        "en-US": {
          "name": "BusWatch Home",
          "summary": "Real-time bus arrival display for Echo Show.",
          "description": "Shows real-time bus arrival info on your Echo Show display.",
          "examplePhrases": [
            "Alexa, open next bus",
            "Alexa, ask next bus for arrival time",
            "Alexa, ask next bus when is the bus"
          ],
          "keywords": ["bus", "arrival", "transit", "commute"]
        }
      },
      "isAvailableWorldwide": false,
      "distributionCountries": [
        "KR"
      ],
      "category": "TRAVEL_AND_TRANSPORTATION"
    },
    "privacyAndCompliance": {
      "locales": {
        "en-US": {
          "privacyPolicyUrl": "",
          "termsOfUseUrl": ""
        }
      },
      "allowsPurchases": false,
      "usesPersonalInfo": false,
      "isChildDirected": false,
      "isExportCompliant": true,
      "containsAds": false
    }
  }
}
